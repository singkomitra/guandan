# Normalize line endings for Unity text files
*.cs       text eol=lf
*.meta     text eol=lf
*.unity    text eol=lf
*.prefab   text eol=lf
*.mat      text eol=lf
*.shader   text eol=lf
*.shadergraph text eol=lf
*.cginc    text eol=lf
*.hlsl     text eol=lf
*.json     text eol=lf
*.asset    text eol=lf
*.txt      text eol=lf

# Unity YAML Smart Merge (UnityYAMLMerge / Smart Merge)
# Use a local git merge driver named 'unityyamlmerge'. Developers must configure
# the `merge.unityyamlmerge.driver` in their local or global git config to point
# to the UnityYAMLMerge executable. See `docs/UNITY_SMART_MERGE.md` for setup.
*.unity    merge=unityyamlmerge
*.prefab   merge=unityyamlmerge
*.asset    merge=unityyamlmerge
